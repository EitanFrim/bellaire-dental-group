# =========================================================================
# Bellaire Dental Group — environment variables
# Copy to .env.local and fill in when credentials are available.
# The site is fully functional WITHOUT these (graceful fallbacks).
# =========================================================================

# Canonical site URL (used for metadata, canonical tags, sitemap, OG)
NEXT_PUBLIC_SITE_URL=https://www.bellairedentalgroup.com

# --- Online scheduler (NexHealth / LocalMed / Adit / etc.) -----------------
# When set, the booking modal renders this scheduler in an iframe instead of
# the request form. Leave blank to use the built-in request form.
NEXT_PUBLIC_SCHEDULER_URL=

# --- Google Places API (live reviews) --------------------------------------
# When both are set, /api/google-reviews serves live reviews; otherwise it
# falls back to the curated real reviews in lib/reviews.ts.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# --- Appointment-request notifications -------------------------------------
# Where appointment-request form submissions are emailed. (Wire to a provider
# such as Resend/SendGrid in app/api/book/route.ts.)
BOOKING_NOTIFICATION_EMAIL=
RESEND_API_KEY=

# --- Analytics -------------------------------------------------------------
NEXT_PUBLIC_GA_ID=
